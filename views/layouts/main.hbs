<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} | БлогПлатформа</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="header">
        <div class="nav-container">
            <a href="/" class="logo">
                <i class="fas fa-blog"></i> блог·платформа
            </a>
            <div class="nav-links">
                <a href="/">Главная</a>
                <a href="/articles">Статьи</a>
                {{#if user}}
                    <a href="/articles/create" class="btn-write">Написать</a>
                    <div class="user-menu">
                        {{#if user.avatar}}
                            <img src="{{user.avatar}}" class="avatar" alt="{{user.username}}">
                        {{else}}
                            <div class="avatar-placeholder">
                                <i class="fas fa-user-circle"></i>
                            </div>
                        {{/if}}
                        <div class="user-dropdown">
                            <a href="/profile/{{user.id}}"><i class="fas fa-user"></i> Профиль</a>
                            <a href="/articles?author={{user.username}}"><i class="fas fa-newspaper"></i> Мои статьи</a>
                            <a href="/favorites"><i class="fas fa-heart"></i> Избранное</a>
                            <a href="/logout"><i class="fas fa-sign-out-alt"></i> Выйти</a>
                        </div>
                    </div>
                {{else}}
                    <a href="/login" class="btn-auth">Вход</a>
                    <a href="/register" class="btn-auth">Регистрация</a>
                {{/if}}
            </div>
        </div>
    </header>

    <main class="container">
        {{#if success}}<div class="alert alert-success">{{success}}</div>{{/if}}
        {{#if error}}<div class="alert alert-error">{{error}}</div>{{/if}}
        {{{body}}}
    </main>

    <footer class="footer">
        <p>© 2026 блог·платформа — место для ваших мыслей</p>
    </footer>

    <script src="/js/main.js"></script>
</body>
</html>
