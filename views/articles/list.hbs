<div class="filters-bar">
    <div class="filters-left">
        <div class="filter-group">
            <label><i class="fas fa-search"></i> Поиск:</label>
            <input type="text" class="filter-input" id="searchInput" placeholder="По заголовку..." value="{{search}}">
        </div>
        <div class="filter-group">
            <label><i class="fas fa-filter"></i> Категория:</label>
            <select class="filter-select" id="categorySelect">
                <option value="all">Все категории</option>
                {{#each categories}}
                    <option value="{{this}}" {{#if (eq this ../category)}}selected{{/if}}>{{this}}</option>
                {{/each}}
            </select>
        </div>
        <div class="filter-group">
            <label><i class="fas fa-user"></i> Автор:</label>
            <input type="text" class="filter-input" id="authorInput" placeholder="Имя автора..." value="{{author}}">
        </div>
        <div class="filter-group">
            <label><i class="fas fa-sort"></i> Сортировать:</label>
            <select class="filter-select" id="sortSelect">
                <option value="newest" {{#if (eq sort "newest")}}selected{{/if}}>📅 Новые сначала</option>
                <option value="oldest" {{#if (eq sort "oldest")}}selected{{/if}}>📅 Старые сначала</option>
                <option value="most_liked" {{#if (eq sort "most_liked")}}selected{{/if}}>❤️ По лайкам</option>
            </select>
        </div>
    </div>
    <button class="btn-reset" id="resetFilters"><i class="fas fa-times"></i> Сбросить</button>
</div>

<script>
    function applyFilters() {
        const search = document.getElementById('searchInput').value;
        const category = document.getElementById('categorySelect').value;
        const author = document.getElementById('authorInput').value;
        const sort = document.getElementById('sortSelect').value;
        
        const params = new URLSearchParams();
        if (search) params.append('search', search);
        if (category && category !== 'all') params.append('category', category);
        if (author) params.append('author', author);
        if (sort) params.append('sort', sort);
        
        window.location.href = '/articles?' + params.toString();
    }
    
    document.getElementById('searchInput').addEventListener('input', function() {
        const timeout = this.timeout;
        clearTimeout(timeout);
        this.timeout = setTimeout(() => applyFilters(), 500);
    });
    document.getElementById('authorInput').addEventListener('input', function() {
        const timeout = this.timeout;
        clearTimeout(timeout);
        this.timeout = setTimeout(() => applyFilters(), 500);
    });
    document.getElementById('categorySelect').addEventListener('change', applyFilters);
    document.getElementById('sortSelect').addEventListener('change', applyFilters);
    document.getElementById('resetFilters').addEventListener('click', () => {
        window.location.href = '/articles';
    });
</script>

<h1>📚 Все статьи</h1>

{{#if articles.length}}
    <div class="articles-grid">
        {{#each articles}}
            <div class="card">
                {{#if this.image}}
                    <img src="{{this.image}}" class="article-image" alt="{{this.title}}">
                {{/if}}
                <div class="article-content">
                    <h3 class="article-title"><a href="/articles/{{this.id}}">{{this.title}}</a></h3>
                    <div class="article-meta">
                        <span><i class="fas fa-user"></i> {{this.author.username}}</span>
                        <span><i class="far fa-calendar-alt"></i> {{formatDate this.createdAt}}</span>
                        <span><i class="fas fa-eye"></i> {{this.views}}</span>
                        <span><i class="fas fa-heart"></i> {{this.likesCount}}</span>
                    </div>
                    <div class="article-meta">
                        <span><i class="fas fa-folder"></i> {{this.category}}</span>
                        {{#if this.tags.length}}
                            <span><i class="fas fa-tags"></i> {{#each this.tags}}#{{this}} {{/each}}</span>
                        {{/if}}
                    </div>
                    <p class="article-excerpt">{{truncate this.content 120}}</p>
                    <a href="/articles/{{this.id}}" class="btn btn-outline" style="margin-top: 0.5rem;">Читать →</a>
                </div>
            </div>
        {{/each}}
    </div>
{{else}}
    <div style="text-align: center; padding: 3rem; background: white; border-radius: var(--radius);">
        <i class="fas fa-newspaper" style="font-size: 3rem; color: var(--gray);"></i>
        <h2 style="margin: 1rem 0;">Статей не найдено</h2>
        <p>Попробуйте изменить параметры поиска или <a href="/articles/create">напишите первую статью</a></p>
    </div>
{{/if}}

{{#if user}}
    <div style="margin-top: 2rem; text-align: center;">
        <a href="/articles/create" class="btn btn-primary"><i class="fas fa-plus"></i> Написать новую статью</a>
    </div>
{{/if}}
