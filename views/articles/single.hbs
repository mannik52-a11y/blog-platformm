<div class="article-page" style="max-width: 900px; margin: 0 auto;">
    <div class="card">
        <!-- Блок видео -->
        {{#if article.video_url}}
            <div class="video-container">
                <iframe src="{{article.video_url}}" frameborder="0" allowfullscreen></iframe>
            </div>
        {{/if}}
        
        <!-- Блок галереи фотографий -->
        {{#if article.images.length}}
            <div class="gallery">
                <div class="gallery-main">
                    <img src="{{article.images.[0]}}" alt="{{article.title}}" id="mainImage" onclick="openFullscreen(this.src)">
                </div>
                <div class="gallery-thumbs">
                    {{#each article.images}}
                        <img src="{{this}}" class="thumb" onclick="document.getElementById('mainImage').src=this.src">
                    {{/each}}
                </div>
            </div>
        {{else if article.image}}
            <img src="{{article.image}}" class="article-image-full" alt="{{article.title}}" onclick="openFullscreen(this.src)">
        {{/if}}
        
        <div class="article-content" style="padding: 2rem;">
            <h1 class="article-title">{{article.title}}</h1>
            <div class="article-meta" style="margin: 1rem 0; display: flex; gap: 1rem; flex-wrap: wrap;">
                <span><i class="fas fa-user"></i> {{article.author.username}}</span>
                <span><i class="far fa-calendar-alt"></i> {{formatDate article.createdAt}}</span>
                <span><i class="fas fa-eye"></i> {{article.views}} просмотров</span>
                <span><i class="fas fa-heart"></i> {{article.likesCount}} лайков</span>
                <span><i class="fas fa-folder"></i> {{article.category}}</span>
            </div>

            {{#if article.tags.length}}
                <div style="margin: 1rem 0;">
                    <strong style="color: rgba(255,255,255,0.9);"><i class="fas fa-tags"></i> Теги:</strong>
                    {{#each article.tags}}
                        <a href="/articles?tag={{this}}" class="tag">#{{this}}</a>
                    {{/each}}
                </div>
            {{/if}}

            <div class="article-body" style="line-height: 1.8; font-size: 1.1rem; white-space: pre-wrap;">
                {{{article.content}}}
            </div>

            <div style="margin: 2rem 0; display: flex; gap: 1rem; flex-wrap: wrap;">
                {{#if user}}
                    <form method="POST" action="/articles/{{article.id}}/like">
                        <button type="submit" class="like-btn {{#if article.userLiked}}liked{{/if}}">
                            <i class="fas fa-heart"></i>
                            <span class="likes-count">{{article.likesCount}}</span>
                        </button>
                    </form>
                    
                    <form method="POST" action="/articles/{{article.id}}/favorite">
                        <button type="submit" class="favorite-btn {{#if article.isFavorite}}favorited{{/if}}">
                            <i class="fas fa-bookmark"></i>
                            <span>{{#if article.isFavorite}}В избранном{{else}}В избранное{{/if}}</span>
                        </button>
                    </form>
                {{/if}}
                
                {{#if isAuthor}}
                    <a href="/articles/{{article.id}}/edit" class="btn btn-primary"><i class="fas fa-edit"></i> Редактировать</a>
                    <form method="POST" action="/articles/{{article.id}}?_method=DELETE" style="display: inline;">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Удалить статью?')"><i class="fas fa-trash"></i> Удалить</button>
                    </form>
                {{/if}}
                
                {{#if isAdmin}}
                    <form method="POST" action="/admin/articles/{{article.id}}?_method=DELETE" style="display: inline;">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Удалить статью как админ?')"><i class="fas fa-trash"></i> Удалить (админ)</button>
                    </form>
                {{/if}}
            </div>

            <div class="comments-section">
                <h2><i class="fas fa-comments"></i> Комментарии ({{comments.length}})</h2>

                {{#if user}}
                    <form method="POST" action="/articles/{{article.id}}/comments" style="margin: 1rem 0;">
                        <textarea name="content" class="form-control" rows="3" placeholder="Написать комментарий..." required></textarea>
                        <button type="submit" class="btn btn-primary" style="margin-top: 0.5rem;"><i class="fas fa-paper-plane"></i> Отправить</button>
                    </form>
                {{else}}
                    <p><a href="/login">Войдите</a>, чтобы оставить комментарий</p>
                {{/if}}

                {{#each comments}}
                    <div class="comment">
                        <div class="comment-author">
                            <i class="fas fa-user-circle"></i> <a href="/profile/{{this.author.id}}">{{this.author.username}}</a>
                            <span style="font-size: 0.8rem; opacity: 0.7;"> — {{formatDate this.createdAt}}</span>
                        </div>
                        <p>{{this.content}}</p>
                        {{#if (or (eq ../user.id this.author.id) ../isAuthor ../isAdmin)}}
                            <form method="POST" action="/comments/{{this.id}}/delete" style="margin-top: 0.5rem;">
                                <button type="submit" class="btn-delete" style="padding: 0.2rem 0.5rem;"><i class="fas fa-trash"></i> Удалить</button>
                            </form>
                        {{/if}}
                    </div>
                {{/each}}
            </div>
        </div>
    </div>
</div>

<!-- Модальное окно для полноэкранного просмотра -->
<div id="fullscreenModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); z-index: 9999; align-items: center; justify-content: center; flex-direction: column; cursor: pointer;">
    <div style="position: absolute; top: 20px; right: 30px; color: white; font-size: 40px; cursor: pointer; z-index: 10000;" onclick="closeFullscreen()">
        <i class="fas fa-times"></i>
    </div>
    <div style="position: absolute; top: 20px; left: 30px; color: white; font-size: 20px; cursor: pointer; z-index: 10000; background: rgba(0,0,0,0.5); padding: 10px 20px; border-radius: 8px;" onclick="closeFullscreen()">
        <i class="fas fa-arrow-left"></i> Назад
    </div>
    <div id="fullscreenImageContainer" style="display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; padding: 80px;">
        <img id="fullscreenImage" src="" alt="Полноэкранный просмотр" style="max-width: 90%; max-height: 90%; object-fit: contain; border-radius: 8px; box-shadow: 0 0 40px rgba(0,0,0,0.5);">
    </div>
</div>

<script>
// Открытие полноэкранного режима
function openFullscreen(src) {
    const modal = document.getElementById('fullscreenModal');
    const img = document.getElementById('fullscreenImage');
    img.src = src;
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    
    // Переключение стрелками
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeFullscreen();
        }
    });
}

// Закрытие полноэкранного режима
function closeFullscreen() {
    const modal = document.getElementById('fullscreenModal');
    modal.style.display = 'none';
    document.body.style.overflow = 'auto';
}

// Закрытие при клике на фон
document.getElementById('fullscreenModal').addEventListener('click', function(e) {
    if (e.target === this) {
        closeFullscreen();
    }
});
</script>

<style>
    .video-container { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; margin-bottom: 1rem; }
    .video-container iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border-radius: 12px; }
    
    .gallery { margin-bottom: 1rem; }
    .gallery-main img { width: 100%; max-height: 400px; object-fit: cover; border-radius: 12px; cursor: pointer; transition: transform 0.3s; }
    .gallery-main img:hover { transform: scale(1.01); }
    
    .gallery-thumbs { display: flex; gap: 0.5rem; margin-top: 0.5rem; flex-wrap: wrap; }
    .gallery-thumbs img { width: 80px; height: 80px; object-fit: cover; border-radius: 8px; cursor: pointer; transition: opacity 0.3s; border: 2px solid transparent; }
    .gallery-thumbs img:hover { opacity: 0.7; border-color: #667eea; }
    
    .article-image-full { width: 100%; max-height: 400px; object-fit: cover; border-radius: 12px; margin-bottom: 1rem; cursor: pointer; transition: transform 0.3s; }
    .article-image-full:hover { transform: scale(1.01); }
    
    .btn-delete { background: rgba(0,0,0,0.3); border: none; border-radius: 4px; color: white; cursor: pointer; padding: 0.2rem 0.5rem; }
    .btn-delete:hover { background: #ef4444; }
    
    /* Кнопка лайка */
    .like-btn { background: transparent; border: 1px solid rgba(255,255,255,0.3); border-radius: 40px; padding: 0.5rem 1.2rem; cursor: pointer; transition: all 0.3s ease; display: inline-flex; align-items: center; gap: 0.5rem; font-size: 1rem; color: rgba(255,255,255,0.8); }
    .like-btn i { font-size: 1.1rem; transition: all 0.3s ease; }
    .like-btn:hover { transform: scale(1.05); border-color: #ff6b6b; }
    .like-btn.liked { background: #ff6b6b; border-color: #ff6b6b; color: white; }
    .like-btn.liked i { color: white; }
    
    .favorite-btn { background: transparent; border: 1px solid rgba(255,255,255,0.3); border-radius: 40px; padding: 0.5rem 1.2rem; cursor: pointer; transition: all 0.3s ease; display: inline-flex; align-items: center; gap: 0.5rem; font-size: 1rem; color: rgba(255,255,255,0.8); }
    .favorite-btn i { font-size: 1rem; }
    .favorite-btn:hover { transform: scale(1.05); border-color: #f59e0b; }
    .favorite-btn.favorited { background: #f59e0b; border-color: #f59e0b; color: white; }
    
    .likes-count { font-weight: 500; }
    
    @media (max-width: 768px) {
        .gallery-thumbs img { width: 50px; height: 50px; }
        .gallery-main img { max-height: 250px; }
        .article-image-full { max-height: 250px; }
        #fullscreenImageContainer { padding: 40px; }
        #fullscreenImage { max-width: 95%; max-height: 85%; }
    }
</style>
