<div class="article-page" style="max-width: 900px; margin: 0 auto;">
    <div class="card">
        {{#if article.image}}
            <img src="{{article.image}}" alt="{{article.title}}" style="width: 100%; max-height: 400px; object-fit: cover;">
        {{/if}}
        <div class="article-content" style="padding: 2rem;">
            <h1>{{article.title}}</h1>
            <div class="article-meta" style="margin: 1rem 0;">
                <span><i class="fas fa-user"></i> {{article.author.username}}</span>
                <span><i class="far fa-calendar-alt"></i> {{formatDate article.createdAt}}</span>
                <span><i class="fas fa-eye"></i> {{article.views}} просмотров</span>
                <span><i class="fas fa-heart"></i> {{article.likesCount}}</span>
                <span><i class="fas fa-folder"></i> {{article.category}}</span>
            </div>

            {{#if article.tags.length}}
                <div style="margin: 1rem 0;">
                    <strong><i class="fas fa-tags"></i> Теги:</strong>
                    {{#each article.tags}}
                        <a href="/articles?tag={{this}}" class="tag">#{{this}}</a>
                    {{/each}}
                </div>
            {{/if}}

            <div style="line-height: 1.8; font-size: 1.1rem; white-space: pre-wrap;">
                {{article.content}}
            </div>

            <div style="margin: 2rem 0; display: flex; gap: 1rem; flex-wrap: wrap;">
                {{#if user}}
                    <form method="POST" action="/articles/{{article.id}}/like">
                        <button type="submit" class="like-btn {{#if article.userLiked}}liked{{/if}}">
                            <i class="fas fa-heart"></i>
                            <span class="likes-count">{{article.likesCount}}</span>
                        </button>
                    </form>
                {{else}}
                    <button class="like-btn" disabled style="opacity: 0.5; cursor: not-allowed;">
                        <i class="fas fa-heart"></i>
                        <span class="likes-count">{{article.likesCount}}</span>
                    </button>
                {{/if}}
                {{#if isAuthor}}
                    <a href="/articles/{{article.id}}/edit" class="btn btn-primary"><i class="fas fa-edit"></i> Редактировать</a>
                    <form method="POST" action="/articles/{{article.id}}?_method=DELETE" style="display: inline;">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Удалить статью?')"><i class="fas fa-trash"></i> Удалить</button>
                    </form>
                {{/if}}
                {{#if isAdmin}}
                    <form method="POST" action="/admin/articles/{{article.id}}?_method=DELETE" style="display: inline;">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Удалить статью как админ?')"><i class="fas fa-trash"></i> Удалить (админ)</button>
                    </form>
                {{/if}}
            </div>

            <div class="comments-section">
                <h2><i class="fas fa-comments"></i> Комментарии ({{comments.length}})</h2>

                {{#if user}}
                    <form method="POST" action="/articles/{{article.id}}/comments" style="margin: 1rem 0;">
                        <textarea name="content" class="form-control" rows="3" placeholder="Написать комментарий..." required></textarea>
                        <button type="submit" class="btn btn-primary" style="margin-top: 0.5rem;"><i class="fas fa-paper-plane"></i> Отправить</button>
                    </form>
                {{else}}
                    <p><a href="/login">Войдите</a>, чтобы оставить комментарий</p>
                {{/if}}

                {{#each comments}}
                    <div class="comment">
                        <div class="comment-author">
                            <i class="fas fa-user-circle"></i> <a href="/profile/{{this.author.id}}">{{this.author.username}}</a>
                            <span style="font-size: 0.8rem; color: var(--gray);"> — {{formatDate this.createdAt}}</span>
                            {{#if (eq ../user.id this.author.id)}}
                                <form method="POST" action="/comments/{{this.id}}/delete" style="display: inline; float: right;">
                                    <button type="submit" class="delete-comment" onclick="return confirm('Удалить комментарий?')"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            {{/if}}
                            {{#if ../isAdmin}}
                                <form method="POST" action="/admin/comments/{{this.id}}?_method=DELETE" style="display: inline; float: right; margin-right: 0.5rem;">
                                    <button type="submit" class="delete-comment" onclick="return confirm('Удалить комментарий как админ?')"><i class="fas fa-shield-alt"></i></button>
                                </form>
                            {{/if}}
                        </div>
                        <p>{{this.content}}</p>
                    </div>
                {{/each}}
            </div>
        </div>
    </div>
</div>

<style>
    .like-btn {
        background: none;
        border: 1px solid var(--border);
        padding: 0.5rem 1rem;
        border-radius: 40px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        transition: all 0.3s;
        font-size: 1rem;
    }
    .like-btn i {
        color: var(--gray);
        font-size: 1rem;
    }
    .like-btn.liked i {
        color: var(--danger);
    }
    .like-btn.liked {
        border-color: var(--danger);
        background: rgba(239, 68, 68, 0.1);
    }
    .like-btn:hover {
        transform: scale(1.05);
    }
    .like-btn:disabled {
        transform: none;
    }
    .delete-comment {
        background: none;
        border: none;
        color: var(--gray);
        cursor: pointer;
        font-size: 0.8rem;
    }
    .delete-comment:hover { color: var(--danger); }
    .tag {
        display: inline-block;
        background: var(--light);
        padding: 0.2rem 0.7rem;
        border-radius: 20px;
        font-size: 0.8rem;
        color: var(--primary);
        text-decoration: none;
        margin: 0 0.2rem;
    }
    .comment {
        background: var(--light);
        padding: 1rem;
        border-radius: var(--radius);
        margin-bottom: 1rem;
    }
</style>
