<div class="form-container" style="max-width: 800px;">
    <h1><i class="fas fa-edit"></i> Редактировать статью</h1>
    <form method="POST" action="/articles/{{article.id}}?_method=PUT" enctype="multipart/form-data">
        <div class="form-group">
            <label>Заголовок</label>
            <input type="text" name="title" value="{{article.title}}" class="form-control" required>
        </div>
        
        <div class="form-group">
            <label>Категория</label>
            <select name="category" class="form-control">
                <option value="">— Без категории —</option>
                {{#each categories}}
                    <option value="{{this}}" {{#if (eq this ../article.category)}}selected{{/if}}>{{this}}</option>
                {{/each}}
            </select>
        </div>
        
        <div class="form-group">
            <label>Теги (через запятую)</label>
            <input type="text" name="tags" value="{{#each article.tags}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}" class="form-control">
        </div>
        
        <div class="form-group">
            <label>YouTube/Vimeo ссылка</label>
            <input type="url" name="video_url" value="{{article.video_url}}" class="form-control" placeholder="https://www.youtube.com/watch?v=...">
        </div>
        
        <div class="form-group">
            <label>Текущие фотографии</label>
            <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem;">
                {{#each article.images}}
                    <div style="position: relative;">
                        <img src="{{this}}" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px;">
                        <label style="position: absolute; top: 0; right: 0;">
                            <input type="checkbox" name="existing_images" value="{{this}}" checked style="display: none;">
                            <span style="background: rgba(0,0,0,0.5); color: white; padding: 2px 4px; border-radius: 50%; font-size: 12px;">✕</span>
                        </label>
                    </div>
                {{/each}}
            </div>
            <small>Для удаления фото — снимите галочку (будет показано после сохранения)</small>
        </div>
        
        <div class="form-group">
            <label>Добавить новые фотографии</label>
            <input type="file" name="images" class="form-control" accept="image/*" multiple onchange="previewImages(this)">
            <div id="imagePreview" style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem;"></div>
        </div>
        
        <div class="form-group">
            <label>Содержание</label>
            <textarea name="content" class="form-control" rows="12" required>{{article.content}}</textarea>
        </div>
        
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Сохранить изменения</button>
        <a href="/articles/{{article.id}}" class="btn btn-outline">Отмена</a>
    </form>
</div>

<script>
function previewImages(input) {
    const preview = document.getElementById('imagePreview');
    preview.innerHTML = '';
    if (input.files) {
        Array.from(input.files).forEach(file => {
            const reader = new FileReader();
            reader.onload = function(e) {
                const img = document.createElement('img');
                img.src = e.target.result;
                img.style.width = '80px';
                img.style.height = '80px';
                img.style.objectFit = 'cover';
                img.style.borderRadius = '8px';
                preview.appendChild(img);
            };
            reader.readAsDataURL(file);
        });
    }
}
</script>
