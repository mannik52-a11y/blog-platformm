<div class="form-container">
    <h1><i class="fas fa-lock"></i> Сброс пароля</h1>
    <p style="margin-bottom: 1rem; color: #666;">Введите код из письма и новый пароль</p>
    <form method="POST" action="/reset-password">
        <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" class="form-control" required>
        </div>
        <div class="form-group">
            <label>Код из письма</label>
            <input type="text" name="code" class="form-control" placeholder="6-значный код" required>
        </div>
        <div class="form-group">
            <label>Новый пароль</label>
            <input type="password" name="password" class="form-control" required>
        </div>
        <div class="form-group">
            <label>Подтвердите пароль</label>
            <input type="password" name="confirm_password" class="form-control" required>
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%;">Изменить пароль</button>
    </form>
    <p style="margin-top: 1rem; text-align: center;">
        <a href="/forgot-password">← Не пришёл код?</a>
    </p>
</div>
