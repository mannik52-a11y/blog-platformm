<div style="max-width: 400px; margin: 40px auto;">
    <h1 style="text-align: center; margin-bottom: 30px;">📝 Регистрация</h1>
    
    <form method="POST" action="/register" style="background: #f8f9fa; padding: 30px; border-radius: 10px;">
        <div class="form-group">
            <label>Имя пользователя:</label>
            <input type="text" name="username" required>
        </div>
        
        <div class="form-group">
            <label>Email:</label>
            <input type="email" name="email" required>
        </div>
        
        <div class="form-group">
            <label>Пароль:</label>
            <input type="password" name="password" required>
        </div>
        
        <button type="submit" style="width: 100%;">Зарегистрироваться</button>
    </form>
    
    <p style="text-align: center; margin-top: 20px;">
        Уже есть аккаунт? <a href="/login">Войти</a>
    </p>
</div>
