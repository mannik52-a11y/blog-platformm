<div class="profile-container">
    <div class="card" style="text-align: center; padding: 2rem;">
        <div class="profile-avatar">
            <img src="{{profileUser.avatar}}" alt="{{profileUser.username}}" class="avatar-large">
        </div>
        <h1>{{profileUser.username}}</h1>
        <p style="color: var(--gray);">{{profileUser.email}}</p>
        <p style="color: var(--gray);">На сайте с {{formatDate profileUser.createdAt}}</p>

        {{#if isOwnProfile}}
            <div style="margin-top: 1rem;">
                <form method="POST" action="/profile/{{profileUser.id}}/avatar" enctype="multipart/form-data" style="display: inline-block;">
                    <input type="file" name="avatar" accept="image/*" style="display: none;" id="avatarInput" onchange="this.form.submit()">
                    <button type="button" class="btn btn-outline" onclick="document.getElementById('avatarInput').click()">
                        🖼️ Сменить аватар
                    </button>
                </form>
            </div>
        {{/if}}
    </div>

    <div class="stats-grid">
        <div class="stat-card"><div class="stat-number">{{stats.articles}}</div><div class="stat-label">Статей</div></div>
        <div class="stat-card"><div class="stat-number">{{stats.comments}}</div><div class="stat-label">Комментариев</div></div>
        <div class="stat-card"><div class="stat-number">{{stats.likes}}</div><div class="stat-label">Лайков получил</div></div>
    </div>

    {{#if articles.length}}
        <h2>📄 Мои статьи</h2>
        <div class="articles-grid">
            {{#each articles}}
                <div class="card">
                    {{#if this.image}}
                        <img src="{{this.image}}" class="article-image" alt="{{this.title}}">
                    {{/if}}
                    <div class="article-content">
                        <h3 class="article-title"><a href="/articles/{{this.id}}">{{this.title}}</a></h3>
                        <div class="article-meta">
                            <span>📅 {{formatDate this.createdAt}}</span>
                            <span>👁️ {{this.views}} просмотров</span>
                        </div>
                        <p class="article-excerpt">{{truncate this.content 100}}</p>
                    </div>
                </div>
            {{/each}}
        </div>
    {{/if}}

    {{#if comments.length}}
        <h2>💬 Мои комментарии</h2>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
            {{#each comments}}
                <div class="comment">
                    <div class="comment-author">
                        <a href="/articles/{{this.article.id}}">{{this.article.title}}</a>
                        <span style="font-size: 0.8rem; color: var(--gray);"> — {{formatDate this.createdAt}}</span>
                    </div>
                    <p>{{this.content}}</p>
                </div>
            {{/each}}
        </div>
    {{/if}}
</div>

<style>
    .profile-container { max-width: 1000px; margin: 0 auto; }
    .profile-avatar { margin-bottom: 1rem; }
    .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 2rem 0; }
    .stat-card { background: white; padding: 1rem; border-radius: var(--radius); text-align: center; box-shadow: var(--shadow); }
    .stat-number { font-size: 2rem; font-weight: 700; color: var(--primary); }
    .stat-label { color: var(--gray); }
    h2 { margin: 1.5rem 0 1rem; font-size: 1.3rem; }
</style>
