<div class="profile-container">
    <div class="profile-card">
        <h1 class="profile-name">{{profileUser.username}}</h1>
        
        <div class="profile-details">
            <div class="profile-row">
                <span class="profile-label">email</span>
                <span class="profile-value">{{profileUser.email}}</span>
            </div>
            <div class="profile-row">
                <span class="profile-label">на сайте с</span>
                <span class="profile-value">{{formatDate profileUser.createdAt}}</span>
            </div>
        </div>
        
        {{#if isOwnProfile}}
            <div class="profile-badge">это вы</div>
        {{/if}}
    </div>
    
    <div class="profile-stats">
        <div class="stat-item">
            <div class="stat-number">{{stats.articles}}</div>
            <div class="stat-label">статей</div>
        </div>
        <div class="stat-item">
            <div class="stat-number">{{stats.comments}}</div>
            <div class="stat-label">комментариев</div>
        </div>
        <div class="stat-item">
            <div class="stat-number">{{stats.likes}}</div>
            <div class="stat-label">лайков</div>
        </div>
    </div>
    
    {{#if articles.length}}
        <div class="profile-section">
            <h2>статьи</h2>
            <div class="articles-grid">
                {{#each articles}}
                    <div class="article-card">
                        <h3><a href="/articles/{{this.id}}">{{this.title}}</a></h3>
                        <div class="article-meta">
                            <span>{{formatDate this.createdAt}}</span>
                            <span>{{this.views}} просмотров</span>
                        </div>
                    </div>
                {{/each}}
            </div>
        </div>
    {{/if}}
    
    {{#if comments.length}}
        <div class="profile-section">
            <h2>комментарии</h2>
            <div class="comments-list">
                {{#each comments}}
                    <div class="comment-item">
                        <div class="comment-header">
                            <a href="/articles/{{this.article.id}}" class="comment-article-title">{{this.article.title}}</a>
                            <span class="comment-date">{{formatDate this.createdAt}}</span>
                        </div>
                        <p class="comment-text">{{this.content}}</p>
                    </div>
                {{/each}}
            </div>
        </div>
    {{/if}}
</div>

<style>
    .profile-container {
        max-width: 900px;
        margin: 0 auto;
    }
    
    .profile-card {
        background: var(--bg-card);
        border-radius: 24px;
        padding: 2rem;
        text-align: center;
        border: 1px solid var(--border);
        margin-bottom: 2rem;
    }
    
    .profile-name {
        font-size: 2rem;
        margin-bottom: 1.5rem;
    }
    
    .profile-details {
        text-align: left;
        max-width: 300px;
        margin: 0 auto;
    }
    
    .profile-row {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--border);
    }
    
    .profile-label {
        font-weight: 500;
        color: var(--text-secondary);
    }
    
    .profile-value {
        color: var(--text-primary);
    }
    
    .profile-badge {
        display: inline-block;
        margin-top: 1rem;
        padding: 0.3rem 1rem;
        background: var(--accent-light);
        color: var(--accent-dark);
        border-radius: 20px;
        font-size: 0.8rem;
    }
    
    .profile-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }
    
    .stat-item {
        background: var(--bg-card);
        border-radius: 20px;
        padding: 1rem;
        text-align: center;
        border: 1px solid var(--border);
    }
    
    .stat-number {
        font-size: 1.8rem;
        font-weight: 550;
        color: var(--accent);
    }
    
    .stat-label {
        font-size: 0.75rem;
        color: var(--text-secondary);
        text-transform: uppercase;
    }
    
    .profile-section {
        margin-bottom: 2rem;
    }
    
    .profile-section h2 {
        margin-bottom: 1rem;
        font-size: 1.3rem;
    }
    
    .comments-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    
    .comment-item {
        background: var(--bg-card);
        border-radius: 16px;
        padding: 1rem;
        border: 1px solid var(--border);
        transition: var(--transition);
    }
    
    .comment-item:hover {
        transform: translateX(4px);
        border-color: var(--accent-light);
    }
    
    .comment-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    
    .comment-article-title {
        font-weight: 550;
        color: var(--accent);
        text-decoration: none;
    }
    
    .comment-article-title:hover {
        color: var(--accent-dark);
        text-decoration: underline;
    }
    
    .comment-date {
        font-size: 0.7rem;
        color: var(--text-secondary);
    }
    
    .comment-text {
        color: var(--text-secondary);
        line-height: 1.4;
        font-size: 0.9rem;
    }
    
    .articles-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1rem;
    }
    
    .article-card {
        background: var(--bg-card);
        border-radius: 16px;
        padding: 1rem;
        border: 1px solid var(--border);
        transition: var(--transition);
    }
    
    .article-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }
    
    .article-card h3 {
        margin-bottom: 0.5rem;
    }
    
    .article-card h3 a {
        color: var(--text-primary);
        text-decoration: none;
    }
    
    .article-card h3 a:hover {
        color: var(--accent);
    }
    
    .article-meta {
        display: flex;
        gap: 1rem;
        font-size: 0.7rem;
        color: var(--text-secondary);
    }
    
    @media (max-width: 600px) {
        .articles-grid {
            grid-template-columns: 1fr;
        }
        
        .comment-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
