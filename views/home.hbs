<div class="hero">
    <div class="hero-icon">
        <i class="fas fa-feather-alt"></i>
    </div>
    <h1>Делитесь мыслями,<br>находите единомышленников</h1>
    <div class="hero-buttons">
        <a href="/register" class="btn btn-primary">Начать</a>
        <a href="/login" class="btn btn-outline">Войти</a>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-number">{{stats.articles}}</div>
        <div class="stat-label">статей</div>
    </div>
    <div class="stat-card">
        <div class="stat-number">{{stats.users}}</div>
        <div class="stat-label">авторов</div>
    </div>
    <div class="stat-card">
        <div class="stat-number">{{stats.comments}}</div>
        <div class="stat-label">комментариев</div>
    </div>
    <div class="stat-card">
        <div class="stat-number">{{stats.likes}}</div>
        <div class="stat-label">лайков</div>
    </div>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
    <div class="home-articles-section">
        <h2>Свежие статьи</h2>
        <div class="articles-grid">
            {{#each recentArticles}}
                <div class="article-card">
                    {{#if this.image}}
                        <img src="{{this.image}}" class="article-image" alt="{{this.title}}">
                    {{/if}}
                    <div class="article-content">
                        <div class="article-header">
                            <div class="article-category">{{this.category}}</div>
                            <h3 class="article-title"><a href="/articles/{{this.id}}">{{this.title}}</a></h3>
                        </div>
                        <p class="article-excerpt">{{truncate this.content 100}}</p>
                        <div class="article-meta">
                            <span>{{this.author.username}}</span>
                            <span>{{formatDate this.createdAt}}</span>
                        </div>
                    </div>
                </div>
            {{/each}}
        </div>
    </div>

    <div class="sidebar">
        <div class="widget">
            <h3 class="widget-title">Категории</h3>
            <div class="category-list">
                {{#each categories}}
                    <a href="/articles?category={{this}}" class="category-item">{{this}}</a>
                {{/each}}
            </div>
        </div>

        <div class="widget">
            <h3 class="widget-title">Теги</h3>
            <div class="tag-cloud">
                {{#each popularTags}}
                    <a href="/articles?tag={{this.tag}}" class="tag">#{{this.tag}}</a>
                {{/each}}
            </div>
        </div>
    </div>
</div>
