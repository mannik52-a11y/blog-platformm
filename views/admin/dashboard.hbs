<div style="margin-bottom: 2rem;">
    <h1><i class="fas fa-shield-alt"></i> Админ-панель</h1>
    <p>Управление контентом и пользователями</p>
</div>

<div class="stats-grid" style="margin-bottom: 2rem;">
    <div class="stat-card"><div class="stat-number">{{stats.pending}}</div><div class="stat-label">На модерации</div></div>
    <div class="stat-card"><div class="stat-number">{{stats.users}}</div><div class="stat-label">Пользователей</div></div>
    <div class="stat-card"><div class="stat-number">{{stats.articles}}</div><div class="stat-label">Статей</div></div>
    <div class="stat-card"><div class="stat-number">{{stats.comments}}</div><div class="stat-label">Комментариев</div></div>
</div>

<!-- Статьи на модерацию -->
{{#if pendingArticles.length}}
    <h2><i class="fas fa-clock"></i> На модерации ({{pendingArticles.length}})</h2>
    <div class="articles-grid" style="margin-bottom: 2rem;">
        {{#each pendingArticles}}
            <div class="card">
                {{#if this.image}}<img src="{{this.image}}" class="article-image">{{/if}}
                <div class="article-content">
                    <h3>{{this.title}}</h3>
                    <div class="article-meta">
                        <span><i class="fas fa-user"></i> {{this.author.username}}</span>
                        <span><i class="fas fa-tag"></i> {{this.category}}</span>
                    </div>
                    <p class="article-excerpt">{{truncate this.content 100}}</p>
                    <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                        <form method="POST" action="/admin/articles/{{this.id}}/approve" style="display: inline;">
                            <button type="submit" class="btn btn-primary" style="background: #10b981;"><i class="fas fa-check"></i> Одобрить</button>
                        </form>
                        <form method="POST" action="/admin/articles/{{this.id}}/reject" style="display: inline;">
                            <button type="submit" class="btn btn-danger"><i class="fas fa-times"></i> Отклонить</button>
                        </form>
                    </div>
                </div>
            </div>
        {{/each}}
    </div>
{{/if}}

<!-- Все пользователи -->
<h2><i class="fas fa-users"></i> Пользователи</h2>
<div style="overflow-x: auto;">
    <table style="width: 100%; background: white; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow);">
        <thead>
            <tr><th style="padding: 1rem; text-align: left; background: var(--primary); color: white;">ID</th><th>Имя</th><th>Email</th><th>Статус</th><th>Статей</th><th>Действия</th></tr>
        </thead>
        <tbody>
            {{#each users}}
                <tr style="border-bottom: 1px solid var(--border);">
                    <td style="padding: 0.8rem;">{{this.id}}</td>
                    <td style="padding: 0.8rem;">{{this.username}}</td>
                    <td style="padding: 0.8rem;">{{this.email}}</td>
                    <td style="padding: 0.8rem;">
                        {{#if (eq this.status "banned")}}
                            <span style="color: var(--danger);">🔒 Заблокирован</span>
                        {{else}}
                            <span style="color: var(--success);">✅ Активен</span>
                        {{/if}}
                    </td>
                    <td style="padding: 0.8rem;">{{../this.articles.length}}</td>
                    <td style="padding: 0.8rem;">
                        {{#if (eq this.status "banned")}}
                            <form method="POST" action="/admin/users/{{this.id}}/unban" style="display: inline;">
                                <button type="submit" class="btn btn-primary" style="background: #10b981; padding: 0.3rem 0.8rem;"><i class="fas fa-unlock-alt"></i> Разблокировать</button>
                            </form>
                        {{else}}
                            <form method="POST" action="/admin/users/{{this.id}}/ban" style="display: inline;">
                                <button type="submit" class="btn btn-danger" style="padding: 0.3rem 0.8rem;"><i class="fas fa-lock"></i> Заблокировать</button>
                            </form>
                        {{/if}}
                    </td>
                </tr>
            {{/each}}
        </tbody>
    </table>
</div>

<!-- Все статьи -->
<h2 style="margin-top: 2rem;"><i class="fas fa-newspaper"></i> Все статьи</h2>
<div style="overflow-x: auto;">
    <table style="width: 100%; background: white; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow);">
        <thead>
            <tr><th style="padding: 1rem; text-align: left; background: var(--primary); color: white;">ID</th><th>Заголовок</th><th>Автор</th><th>Статус</th><th>Дата</th><th>Действия</th></tr>
        </thead>
        <tbody>
            {{#each articles}}
                <tr style="border-bottom: 1px solid var(--border);">
                    <td style="padding: 0.8rem;">{{this.id}}</td>
                    <td style="padding: 0.8rem;"><a href="/articles/{{this.id}}">{{this.title}}</a></td>
                    <td style="padding: 0.8rem;">{{this.author.username}}</td>
                    <td style="padding: 0.8rem;">
                        {{#if (eq this.status "published")}}
                            <span style="color: var(--success);">✅ Опубликована</span>
                        {{else if (eq this.status "pending")}}
                            <span style="color: var(--secondary);">⏳ На модерации</span>
                        {{else}}
                            <span style="color: var(--danger);">❌ Отклонена</span>
                        {{/if}}
                    </td>
                    <td style="padding: 0.8rem;">{{formatDate this.createdAt}}</td>
                    <td style="padding: 0.8rem;">
                        <form method="POST" action="/admin/articles/{{this.id}}?_method=DELETE" style="display: inline;">
                            <button type="submit" class="btn btn-danger" style="padding: 0.3rem 0.8rem;" onclick="return confirm('Удалить статью?')"><i class="fas fa-trash"></i> Удалить</button>
                        </form>
                    </td>
                </tr>
            {{/each}}
        </tbody>
    </table>
</div>

<!-- Все комментарии -->
<h2 style="margin-top: 2rem;"><i class="fas fa-comments"></i> Комментарии</h2>
<div style="overflow-x: auto;">
    <table style="width: 100%; background: white; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow);">
        <thead>
            <tr><th style="padding: 1rem; text-align: left; background: var(--primary); color: white;">ID</th><th>Текст</th><th>Автор</th><th>К статье</th><th>Дата</th><th>Действия</th></tr>
        </thead>
        <tbody>
            {{#each comments}}
                <tr style="border-bottom: 1px solid var(--border);">
                    <td style="padding: 0.8rem;">{{this.id}}</td>
                    <td style="padding: 0.8rem;">{{truncate this.content 50}}</td>
                    <td style="padding: 0.8rem;">{{this.author.username}}</td>
                    <td style="padding: 0.8rem;"><a href="/articles/{{this.articleId}}">Статья #{{this.articleId}}</a></td>
                    <td style="padding: 0.8rem;">{{formatDate this.createdAt}}</td>
                    <td style="padding: 0.8rem;">
                        <form method="POST" action="/admin/comments/{{this.id}}?_method=DELETE" style="display: inline;">
                            <button type="submit" class="btn btn-danger" style="padding: 0.3rem 0.8rem;" onclick="return confirm('Удалить комментарий?')"><i class="fas fa-trash"></i> Удалить</button>
                        </form>
                    </td>
                </tr>
            {{/each}}
        </tbody>
    </table>
</div>

<style>
    table { border-collapse: collapse; width: 100%; }
    td, th { text-align: left; padding: 0.8rem; }
    th { background: var(--primary); color: white; }
    tr:hover { background: var(--light); }
</style>
