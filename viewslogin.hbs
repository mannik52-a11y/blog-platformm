<div style="max-width: 400px; margin: 40px auto;">
    <h1 style="text-align: center; margin-bottom: 30px;">🔑 Вход в аккаунт</h1>
    
    <form method="POST" action="/login" style="background: #f8f9fa; padding: 30px; border-radius: 10px;">
        <div class="form-group">
            <label>Email:</label>
            <input type="email" name="email" placeholder="Введите ваш email" required>
        </div>
        
        <div class="form-group">
            <label>Пароль:</label>
            <input type="password" name="password" placeholder="Введите пароль" required>
        </div>
        
        <button type="submit" class="btn" style="width: 100%;">Войти</button>
    </form>
    
    <p style="text-align: center; margin-top: 20px;">
        Нет аккаунта? <a href="/register" style="color: #667eea;">Зарегистрируйтесь</a>
    </p>
</div>